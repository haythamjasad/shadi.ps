{
  "name": "shop-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "build": "rm -rf dist && esbuild src/index.js --bundle --platform=node --format=cjs --outfile=dist/index.js && node -e \"require('fs').writeFileSync('dist/package.json', JSON.stringify({type:'commonjs'}))\"",
    "test": "node --test",
    "migrate:product-docs": "node scripts/migrate-legacy-product-docs.js",
    "backfill:admin-permissions": "node scripts/backfill-admin-permissions.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.0",
    "nodemailer": "^6.9.14",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.1"
  }
}
