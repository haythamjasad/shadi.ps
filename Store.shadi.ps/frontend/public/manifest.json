    },
    {
      "src": "screenshots/acc-app.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "platform": "narrow",
      "label": "كتالوج المنتجات - عرض الهاتف"
    },
    {
      "src": "screenshots/home-web.png",
      "sizes": "1920x1080",
      "type": "image/png",
